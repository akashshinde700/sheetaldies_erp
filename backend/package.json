{
  "name": "sheetal-dies-erp-backend",
  "version": "1.0.0",
  "description": "Sheetal Dies & Tools ERP Backend - Node.js + Express + Prisma + MySQL",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:truncate": "node scripts/truncate-all-tables.js",
    "db:seed-parties": "node scripts/seed-parties.js",
    "db:seed-machines": "node scripts/seed-machines.js",
    "db:assign-jobcard-machine-drawing": "node scripts/assign-machines-drawing-to-jobcards.js",
    "db:advance-workflow": "node scripts/seed-advance-workflow.js",
    "db:seed-jobcards": "node scripts/seed-jobcards-from-parties.js",
    "db:ensure-admin": "node scripts/ensure-admin-user.js",
    "db:seed": "node src/utils/seed.js",
    "test:e2e:workflow": "node scripts/e2e-workflow-flow-test.js",
    "test": "node --test test/smoke.test.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.11",
    "pdfkit": "^0.18.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
