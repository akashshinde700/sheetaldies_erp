# ============================================================
# SHEETAL DIES & TOOLS ERP - ENVIRONMENT CONFIGURATION
# ============================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control
# ============================================================

# ── APPLICATION ────────────────────────────────────────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=debug

# ── DATABASE ───────────────────────────────────────────────
# MySQL database connection string
# Format: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/sheetal_dies_erp

# Direct database URL for Prisma
PRISMA_DATABASE_URL=${DATABASE_URL}

# ── FRONTEND ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── JWT / AUTHENTICATION ────────────────────────────────────
# JWT Secret for signing tokens (generate: openssl rand -hex 32)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiry times
JWT_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ── ENCRYPTION ─────────────────────────────────────────────
# Encryption key for sensitive fields (GSTIN, PAN, Bank account)
# Generate: openssl rand -hex 32
# WARNING: Never change this after encrypting data (data loss!)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_change_this

# ── EMAIL / NOTIFICATIONS ──────────────────────────────────
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email sender address
MAIL_FROM=noreply@sheetaldies.com
MAIL_FROM_NAME=Sheetal Dies ERP

# ── SMS / WHATSAPP (Optional) ──────────────────────────────
# Twilio or similar SMS service credentials
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=SHETAL

# ── FILE STORAGE ───────────────────────────────────────────
# Local file storage directory
UPLOADS_DIR=./uploads

# Max file upload size (in MB)
MAX_FILE_SIZE_MB=50

# ── RATE LIMITING ──────────────────────────────────────────
# General API rate limit (requests per 15 minutes)
RATE_LIMIT_GENERAL=100

# Strict operations rate limit (requests per hour)
RATE_LIMIT_STRICT=20

# File upload rate limit (uploads per hour)
RATE_LIMIT_UPLOADS=10

# ── LOGGING ────────────────────────────────────────────────
# Log file location
LOG_DIR=./logs

# Maximum log file size before rotation (in MB)
LOG_MAX_SIZE_MB=10

# ── CORS ───────────────────────────────────────────────────
# Allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── DATABASE BACKUP ────────────────────────────────────────
# Auto-backup settings
ENABLE_AUTO_BACKUP=true
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30

# ── MONITORING & ANALYTICS ────────────────────────────────
# Sentry for error tracking (Optional)
SENTRY_DSN=

# DataDog or similar APM (Optional)
APM_ENABLED=false

# ── THIRD-PARTY SERVICES ──────────────────────────────────
# GST API integration (if needed)
GST_API_KEY=

# ── DEVELOPMENT ────────────────────────────────────────────
# Enable debug endpoints
DEBUG_ENABLED=true

# Enable demo/seed data
ENABLE_DEMO_ROUTES=true

# Prisma settings
PRISMA_QUERY_LOG=true
PRISMA_ERRORFORMAT=pretty
