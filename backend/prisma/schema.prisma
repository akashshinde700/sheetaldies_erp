  sourceChallanItem ChallanItem? @relation(fields: [sourceChallanItemId], references: [id])
  description     String      @db.VarChar(300)
  material        String?     @db.VarChar(100)
  hrc             String?     @db.VarChar(30)
  woNo            String?     @map("wo_no")   @db.VarChar(50)
  hsnSac          String?     @map("hsn_sac") @db.VarChar(20)
  quantity        Decimal     @db.Decimal(12, 3)
  unit            String      @default("KGS") @db.VarChar(10)
  weight          Decimal?    @db.Decimal(12, 3)
  rate            Decimal     @db.Decimal(12, 2)
  amount          Decimal     @db.Decimal(12, 2)
  processTypeId   Int?        @map("process_type_id")
  processType     ProcessType? @relation(fields: [processTypeId], references: [id])

  @@map("invoice_items")
}

// ============================================================
// 9. AUDIT LOG
// ============================================================
model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  action      String   @db.VarChar(100)
  tableName   String?  @map("table_name") @db.VarChar(100)
  recordId    Int?     @map("record_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address") @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ============================================================
// 10. ENUMS FOR PURCHASE & MANUFACTURING
// ============================================================
enum PurchaseOrderStatus {
  DRAFT
  SENT
  RECEIVED
  COMPLETED
  CANCELLED

  @@map("purchase_order_status")
}

enum GRNStatus {
  RECEIVED
  ACCEPTED
  PARTIAL_REJECTED
  COMPLETED
  CANCELLED

  @@map("grn_status")
}

enum BatchStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED

  @@map("batch_status")
}

enum RunsheetStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED

  @@map("runsheet_status")
}

enum ProductionPlanStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED

  @@map("production_plan_status")
}

enum FurnacePlanStage {
  HARDENING
  TEMPERING
  OTHER

  @@map("furnace_plan_stage")
}

// ============================================================
// 11. PURCHASE ORDER & GRN
// ============================================================
model PurchaseOrder {
  id                Int                   @id @default(autoincrement())
  poNumber          String                @unique @map("po_number") @db.VarChar(50)
  vendorId          Int                   @map("vendor_id")
  vendor            Party                 @relation("PurchaseOrderVendor", fields: [vendorId], references: [id])
  poDate            DateTime              @map("po_date") @db.Date
  expectedDelivery  DateTime?             @map("expected_delivery") @db.Date
  status            PurchaseOrderStatus   @default(DRAFT)
  remarks           String?               @db.Text
  totalAmount       Decimal               @default(0) @map("total_amount") @db.Decimal(12, 2)
  
  createdById       Int                   @map("created_by")
  createdBy         User                  @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  items             PurchaseOrderItem[]
  grns              GRN[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id                Int            @id @default(autoincrement())
  purchaseOrderId   Int            @map("purchase_order_id")
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  itemId            Int            @map("item_id")
  item              Item           @relation(fields: [itemId], references: [id])
  quantity          Int
  unitPrice         Decimal        @map("unit_price") @db.Decimal(12, 2)
  amount            Decimal        @db.Decimal(12, 2)

  @@map("purchase_order_items")
}

model GRN {
  id                Int            @id @default(autoincrement())
  grnNumber         String         @unique @map("grn_number") @db.VarChar(50)
  purchaseOrderId   Int            @map("purchase_order_id")
  purchaseOrder     PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  grnDate           DateTime       @map("grn_date") @db.Date
  status            GRNStatus      @default(RECEIVED)
  remarks           String?        @db.Text

  createdById       Int            @map("created_by")
  createdBy         User           @relation("GRNCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  items             GRNItem[]

  @@map("grns")
}

model GRNItem {
  id                      Int     @id @default(autoincrement())
  grnId                   Int     @map("grn_id")
  grn                     GRN     @relation(fields: [grnId], references: [id], onDelete: Cascade)
  itemId                  Int     @map("item_id")
  item                    Item    @relation(fields: [itemId], references: [id])
  quantityReceived        Int     @map("quantity_received")
  quantityAccepted        Int     @map("quantity_accepted")
  quantityRejected        Int     @map("quantity_rejected")
  remarks                 String? @db.VarChar(300)

  @@map("grn_items")
}

model Inventory {
  id                Int       @id @default(autoincrement())
  itemId            Int       @unique @map("item_id")
  item              Item      @relation(fields: [itemId], references: [id])
  quantityOnHand    Int       @map("quantity_on_hand")
  reorderLevel      Int       @map("reorder_level")
  lastRestockDate   DateTime  @map("last_restock_date") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("inventories")
}

// ============================================================
// 12. MANUFACTURING & BATCH
// ============================================================
model ManufacturingBatch {
  id                Int                   @id @default(autoincrement())
  batchNumber       String                @unique @map("batch_number") @db.VarChar(50)
  batchDate         DateTime              @map("batch_date") @db.Date
  status            BatchStatus           @default(CREATED)
  remarks           String?               @db.Text

  createdById       Int                   @map("created_by")
  createdBy         User                  @relation("ManufacturingBatchCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  jobCards          ManufacturingBatchJobCard[]
  runsheets         VHTRunsheet[]
  productionPlans   ProductionPlan[]

  @@map("manufacturing_batches")
}

model ManufacturingBatchJobCard {
  id                Int                   @id @default(autoincrement())
  batchId           Int                   @map("batch_id")
  batch             ManufacturingBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  jobCardId         Int                   @map("job_card_id")
  jobCard           JobCard               @relation(fields: [jobCardId], references: [id])

  @@unique([batchId, jobCardId])
  @@map("manufacturing_batch_jobcards")
}

model VHTRunsheet {
  id                Int                   @id @default(autoincrement())
  runsheetNumber    String                @unique @map("runsheet_number") @db.VarChar(50)
  batchId           Int?                  @map("batch_id")
  batch             ManufacturingBatch?   @relation(fields: [batchId], references: [id])
  furnaceId         Int                   @map("furnace_id")
  furnace           Machine               @relation(fields: [furnaceId], references: [id])

  /// Run date (same as paper "Date")
  runDate           DateTime              @map("run_date") @db.Date
  cycleEndTime      String?               @map("cycle_end_time") @db.VarChar(10) // "17:10"
  totalTimeDisplay  String?               @map("total_time_display") @db.VarChar(20) // "8:00" hours
  mrStart           Int?                  @map("mr_start")
  mrEnd             Int?                  @map("mr_end")
  totalMr           Int?                  @map("total_mr")
  loadingOperatorName String?             @map("loading_operator_name") @db.VarChar(100)

  docRevNo          String?               @map("doc_rev_no") @db.VarChar(20)
  docEffectiveDate  DateTime?             @map("doc_effective_date") @db.Date
  docPageOf         String?               @map("doc_page_of") @db.VarChar(20) // "1 of 2"

  tempProfile       String?               @map("temp_profile") @db.VarChar(200)
  cycleTime         Int                   @default(240) @map("cycle_time") // total cycle minutes (optional)
  hardeningType     String?               @map("hardening_type") @db.VarChar(200)
  quenchPressureBar Decimal?              @map("quench_pressure_bar") @db.Decimal(6, 2)
  fanRpm            Int?                  @map("fan_rpm")
  fixturesPosition  String?               @map("fixtures_position") @db.VarChar(120)
  /// Step graph: [{ "tempC": 550, "holdMin": 20, "label": "..." }, ...]
  tempGraphPoints   Json?                 @map("temp_graph_points")

  operatorSign      String?               @map("operator_sign") @db.VarChar(150)
  supervisorSign    String?               @map("supervisor_sign") @db.VarChar(150)
  supervisorVerifiedAt DateTime?            @map("supervisor_verified_at")
  verificationNote  String?               @map("verification_note") @db.Text

  status            RunsheetStatus        @default(PLANNED)
  actualOutput      Int?                  @map("actual_output")
  remarks           String?               @db.Text

  createdById       Int                   @map("created_by")
  createdBy         User                  @relation("VHTRunsheetCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  items             VHTRunsheetItem[]

  @@index([runDate, furnaceId])
  @@map("vht_runsheets")
}

model VHTRunsheetItem {
  id                Int            @id @default(autoincrement())
  runsheetId        Int            @map("runsheet_id")
  runsheet          VHTRunsheet    @relation(fields: [runsheetId], references: [id], onDelete: Cascade)

  jobCardId         Int?           @map("job_card_id")
  jobCard           JobCard?       @relation(fields: [jobCardId], references: [id])

  itemId            Int?           @map("item_id")
  item              Item?          @relation(fields: [itemId], references: [id])

  customerName      String?        @map("customer_name") @db.VarChar(200)
  jobDescription    String?        @map("job_description") @db.VarChar(300)
  materialGrade     String?        @map("material_grade") @db.VarChar(100)
  hrcRequired       String?        @map("hrc_required") @db.VarChar(50)

  quantity          Int
  weightKg          Decimal?       @map("weight_kg") @db.Decimal(10, 3)
  plannedSlot       String?        @map("planned_slot") @db.VarChar(20)

  @@index([jobCardId])
  @@map("vht_runsheet_items")
}

model ProductionPlan {
  id                Int                   @id @default(autoincrement())
  batchId           Int                   @map("batch_id")
  batch             ManufacturingBatch    @relation(fields: [batchId], references: [id])
  planDate          DateTime              @map("plan_date") @db.Date
  status            ProductionPlanStatus  @default(DRAFT)

  createdById       Int                   @map("created_by")
  createdBy         User                  @relation("ProductionPlanCreatedBy", fields: [createdById], references: [id])
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  shifts            Shift[]

  @@map("production_plans")
}

model Shift {
  id                Int              @id @default(autoincrement())
  planId            Int              @map("plan_id")
  plan              ProductionPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  shiftNumber       Int              @map("shift_number") // 1, 2, 3
  startTime         DateTime         @map("start_time")
  endTime           DateTime         @map("end_time")
  machineryAssigned String?          @map("machinery_assigned") @db.VarChar(100)
  operatorAssigned  String?          @map("operator_assigned") @db.VarChar(100)
  plannedOutput     Int              @map("planned_output")
  actualOutput      Int?             @map("actual_output")
  reason            String?          @db.VarChar(300) // for downtime

  @@map("shifts")
}
