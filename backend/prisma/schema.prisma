  cgstAmount        Decimal       @default(0)            @map("cgst_amount")       @db.Decimal(12, 2)
  sgstRate          Decimal       @default(9.00)         @map("sgst_rate")         @db.Decimal(5, 2)
  sgstAmount        Decimal       @default(0)            @map("sgst_amount")       @db.Decimal(12, 2)
  igstRate          Decimal       @default(0)            @map("igst_rate")         @db.Decimal(5, 2)
  igstAmount        Decimal       @default(0)            @map("igst_amount")       @db.Decimal(12, 2)
  totalAmount       Decimal       @default(0)            @map("total_amount")      @db.Decimal(12, 2)
  transportFreight  Decimal       @default(0)            @map("transport_freight") @db.Decimal(12, 2)
  tcsRate           Decimal       @default(0)            @map("tcs_rate")          @db.Decimal(5, 2)
  tcsAmount         Decimal       @default(0)            @map("tcs_amount")        @db.Decimal(12, 2)
  extraAmt          Decimal       @default(0)            @map("extra_amt")         @db.Decimal(12, 2)
  grandTotal        Decimal       @default(0)            @map("grand_total")         @db.Decimal(12, 2)
  amountInWords     String?       @map("amount_in_words")    @db.VarChar(300)
  taxAmountInWords  String?       @map("tax_amount_in_words") @db.VarChar(300)

  dispatchDocNo   String?       @map("dispatch_doc_no")  @db.VarChar(100)
  eWayBillNo      String?       @map("e_way_bill_no")    @db.VarChar(50)
  paymentStatus   PaymentStatus @default(PENDING)      @map("payment_status")
  paidDate        DateTime?     @map("paid_date")      @db.Date
  paymentRef      String?       @map("payment_ref")    @db.VarChar(100)

  sentToTally     Boolean       @default(false)        @map("sent_to_tally")
  sentToTallyAt   DateTime?     @map("sent_to_tally_at")

  createdById     Int           @map("created_by")
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdAt       DateTime      @default(now())        @map("created_at")
  updatedAt       DateTime      @updatedAt             @map("updated_at")

  items           InvoiceItem[]

  @@map("tax_invoices")
}

model InvoiceItem {
  id              Int         @id @default(autoincrement())
  invoiceId       Int         @map("invoice_id")
  invoice         TaxInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  certId          Int?        @map("cert_id")
  cert            TestCertificate? @relation(fields: [certId], references: [id])
